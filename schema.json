                $ref: '#/components/schemas/Cart'
          description: ''
    patch:
      operationId: carts_carts_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this cart.
        required: true
      tags:
      - carts
