  /api/carts/quotes/{id}/cancel_quote/:
    post:
      operationId: carts_quotes_cancel_quote_create
      description: |-
        Cancela una cotización y restaura el stock.
        Puede ser accesible para el usuario (si está pendiente) o para el admin.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this quote.
        required: true
      tags:
      - carts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Quote'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Quote'
          multipart/form-data:
