        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedCart'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedCart'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedCart'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Cart'
          description: ''
    delete:
      operationId: carts_carts_destroy
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this cart.
        required: true
      tags:
      - carts
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/carts/carts/add_item/:
    post:
      operationId: carts_carts_add_item_create
      description: |-
        Agrega o actualiza un producto en el carrito del usuario autenticado.
        Requiere 'product_id' y 'quantity' en el cuerpo de la solicitud.
      tags:
      - carts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Cart'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Cart'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Cart'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Cart'
          description: ''
  /api/carts/carts/create_quote/:
    post:
      operationId: carts_carts_create_quote_create
      description: |-
        Crea una cotización a partir del carrito actual del usuario autenticado.
        Valida stock, crea QuoteItems, calcula total, descuenta stock y vacía el carrito.
      tags:
      - carts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Cart'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Cart'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Cart'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Cart'
          description: ''
  /api/carts/carts/remove_item/{item_id}/:
    delete:
      operationId: carts_carts_remove_item_destroy
      description: |-
        Elimina un item específico del carrito del usuario autenticado.
        Requiere el 'item_id' en la URL.
      parameters:
      - in: path
        name: item_id
        schema:
          type: string
          pattern: ^\d+$
        required: true
      tags:
      - carts
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/carts/quotes/:
